{
  "name": "inferbench-cli",
  "version": "0.1.0",
  "description": "Benchmarks local-LLM-inference engines (omlx, llama.cpp) on your own hardware, live, and recommends the fastest engine/config combination for your model.",
  "keywords": [
    "llm",
    "inference",
    "benchmark",
    "omlx",
    "llama.cpp",
    "mlx",
    "local-llm",
    "apple-silicon",
    "cli"
  ],
  "homepage": "https://github.com/RudrenduPaul/InferBench#readme",
  "bugs": {
    "url": "https://github.com/RudrenduPaul/InferBench/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RudrenduPaul/InferBench.git"
  },
  "license": "Apache-2.0",
  "author": "",
  "type": "module",
  "bin": {
    "inferbench": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
